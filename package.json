{
  "name": "mole",
  "private": true,
  "version": "1.45.0",
  "packageManager": "bun@1.3.7",
  "scripts": {
    "build": "bun run build:workspaces && bun run build:go",
    "build:workspaces": "turbo run build",
    "build:go": "go build ./...",
    "dev": "turbo run dev --parallel",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:build": "bun run --cwd apps/desktop dist",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "stripe:create-test-coupon": "node scripts/create_stripe_test_coupon.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "convex": "^1.17.4",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
